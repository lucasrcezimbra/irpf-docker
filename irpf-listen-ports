#!/bin/sh

# Print TCP listen ports owned by the IRPF Java process.

pid="${1:-}"

if [ -z "$pid" ]; then
    for cmdline in /proc/[0-9]*/cmdline; do
        [ -r "$cmdline" ] || continue
        if tr '\0' ' ' < "$cmdline" | grep -q '/opt/IRPF2026/irpf.jar'; then
            pid="${cmdline#/proc/}"
            pid="${pid%/cmdline}"
            break
        fi
    done
fi

if [ -z "$pid" ]; then
    echo "IRPF Java process not found" >&2
    exit 1
fi

inodes=$(ls -l "/proc/$pid/fd" 2>/dev/null \
    | sed -n 's/.*socket:\[\([0-9][0-9]*\)\].*/\1/p' \
    | tr '\n' ' ')

[ -n "$inodes" ] || exit 0

for table in /proc/net/tcp /proc/net/tcp6; do
    [ -r "$table" ] || continue
    awk 'NR > 1 && $4 == "0A" { print $2, $10 }' "$table"
done | while read -r local_address inode; do
    case " $inodes " in
        *" $inode "*)
            port_hex="${local_address#*:}"
            printf '%d\n' "0x$port_hex"
            ;;
    esac
done | sort -n -u
